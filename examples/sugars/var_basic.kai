# m7b #5 — `var name = init` desugars to a cell-binding plus
# array_get/array_set rewrite for every `name.get()` / `name.set(v)`
# in the rest of the enclosing block. After two increments, the
# counter reads `2`.

fn main() {
  var counter = 0
  counter.set(counter.get() + 1)
  counter.set(counter.get() + 1)
  print(int_to_string(counter.get()))
}
