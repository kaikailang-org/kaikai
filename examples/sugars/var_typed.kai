# m7b #5 — same as var_basic but with the explicit `: Int`
# annotation. The desugar drops the annotation when it produces the
# cell-binding `let counter = array_make(1, 0)` (the cell is
# `Array[Int]` regardless), so the only observable difference vs.
# var_basic is that the parser captured the type expression. Same
# expected output: `2`.

fn main() {
  var counter: Int = 0
  counter.set(counter.get() + 1)
  counter.set(counter.get() + 1)
  print(int_to_string(counter.get()))
}
