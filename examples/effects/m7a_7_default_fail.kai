# m7a #7 — default Fail handler. Doc B catalog says Fail has no
# default (an unhandled Fail in `main`'s row should be a compile
# error), but until the typer's row check in #8 enforces that, the
# runtime ships a fallback default that writes a banner to stderr
# and exits 1. Demo: `Fail.fail("bad input")` aborts the binary
# without returning to main.

fn main() : Int / Fail {
  Fail.fail("bad input")
  0
}
