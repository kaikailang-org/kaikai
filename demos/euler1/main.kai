# Project Euler #1: sum of multiples of 3 or 5 below 1000.

use Console

fn main() = {
  let total = [1..999]
    |> filter((n) => n % 3 == 0 || n % 5 == 0)
    |> sum
  println("Euler 1: #{int_to_string(total)}")
}

test "small range" {
  let total = [1..9] |> filter((n) => n % 3 == 0 || n % 5 == 0) |> sum
  assert total == 23   # 3 + 5 + 6 + 9
}
